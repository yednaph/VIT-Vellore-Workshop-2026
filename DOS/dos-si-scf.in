&control
    calculation = 'scf'
    prefix = 'silicon'
    outdir = './'
    pseudo_dir ='/home/hp/Desktop/test'
    etot_conv_thr = 1e-5
    forc_conv_thr = 1e-4
    verbosity = 'high'
/

&system
    ibrav=2,
    celldm(1) =10.2076,
    nat=2,
    ntyp=1,
    ecutwfc=50
    nbnd=8
/

&electrons
    conv_thr=1e-8
    mixing_beta= 0.6
/

