&control
    calculation = 'vc-relax'
    prefix = 'silicon'
    outdir = './tmp/'
    pseudo_dir ='/home/karan/pseudos'
    etot_conv_thr = 1e-5
    forc_conv_thr = 1e-4
/

&system
    ibrav=2, celldm(1) =10.3395,
    nat=2, ntyp=1,
    ecutwfc=30
/

&electrons
    conv_thr=1e-8
/

&ions
/

&cell
    cell_dofree='ibrav'
/

