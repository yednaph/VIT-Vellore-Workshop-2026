&control
    calculation = 'relax'
    prefix = 'silicon'
    outdir = './tmp/'
    pseudo_dir ='/home/karan/pseudos'
    etot_conv_thr = 1e-5
    forc_conv_thr = 1e-4
/

&system
    ibrav=2, celldm(1) =10.35,
    nat=2, ntyp=1,
    ecutwfc=30
/

&electrons
    conv_thr=1e-8
/

&ions
/

&cell
    cell_dofree='ibrav'
/

ATOMIC_SPECIES
  Si  28.0855  Si.pbe-n-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS (alat)
 Si 0.0 0.0 0.0
 Si 0.25 0.25 0.25

K_POINTS (automatic)
  6 6 6 1 1 1


