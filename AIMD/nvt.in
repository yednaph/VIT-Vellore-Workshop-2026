&control
    calculation = 'cp'
    restart_mode = 'reset_counters'
    prefix = 'silicon',
    outdir = './tmp/',
     pseudo_dir ='/home/karan/pseudos',
    nstep=4000, iprint=10, isave=100,
    dt=3.0,
    ndr=51, ndw=52,        ! folder for reading and writing
    tstress=.true., tprnfor=.true.
/

&system
    ibrav=2, celldm(1) =10.35,
    nat=2, ntyp=1,
    ecutwfc=30
    ecutrho= 200,
    nr1b=30, nr2b=30, nr3b=30, 
    nbnd = 10
/

&electrons
    electron_dynamics = 'verlet'         
    electron_velocities = 'zero'
    emass=200.,
    orthogonalization='ortho',
    ortho_eps=1d-9
/

&ions
    ion_dynamics = 'verlet'  
    ion_velocities = 'zero'       
    ion_temperature = 'nose', fnosep = 30.0, tempw = 300.0
/

ATOMIC_SPECIES
  Si  28.0855  Si.pbe-nl-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS (alat)
Si            0.0000000000        0.0000000000        0.0000000000
Si            0.2500000000        0.2500000000        0.2500000000

K_POINTS automatic
6 6 6 1 1 1
