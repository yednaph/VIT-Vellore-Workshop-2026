&control
    calculation = 'cp'
    restart_mode = 'restart'
    prefix = 'silicon',
    outdir = './tmp/',
     pseudo_dir ='/home/karan/pseudos',
    nstep=4000, iprint=10, isave=100,
    dt=3.0,
    ndr=50, ndw=51,        ! folder for reading and writing
    tstress=.true., tprnfor=.true.
/

&system
    ibrav=2, celldm(1) =10.35,
    nat=2, ntyp=1,
    ecutwfc=30
    ecutrho= 200,
    nr1b=30, nr2b=30, nr3b=30, 
    nbnd = 10
/

&electrons
    electron_dynamics='damp', electron_damping=0.05,
    emass=200.,
    orthogonalization='ortho', ortho_eps=1d-11
/

&ions
    ion_dynamics='none'
     tranp = .true.       ! randomize atomic positions             
    amprp = 0.03         ! displacement amplitude for the randomization
/

ATOMIC_SPECIES
  Si  28.0855  Si.pbe-nl-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS (alat)
Si            0.0000000000        0.0000000000        0.0000000000
Si            0.2500000000        0.2500000000        0.2500000000


