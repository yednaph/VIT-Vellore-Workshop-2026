 &control
    calculation = 'scf'
    restart_mode='from_scratch',
    prefix='silicon',
    pseudo_dir = '/home/karan/pseudos'
    outdir='./'
 /
 &system
    ibrav=  2, 
    celldm(1) =10.35, 
    nat= 2, 
    ntyp= 1,
    ecutwfc=30.0,
    ecutrho = 200
 /
 &electrons
    conv_thr =  1.0d-8
 /
ATOMIC_SPECIES
 Si  28.086  Si.pbe-n-kjpaw_psl.1.0.0.UPF
ATOMIC_POSITIONS (alat)
 Si 0.00 0.00 0.00
 Si 0.25 0.25 0.25
K_POINTS AUTOMATIC
6 6 6 1 1 1 
